{
  "configVersion": "v3",
  "app": {
    "appId": 20275,
    "appName": "RadiaWatch",
    "appType": "app",
    "version": {
      "code": 1,
      "name": "1.0.0"
    },
    "icon": "icon.png",
    "vender": "zepp",
    "description": "Real-time radiation monitor via Radiacode"
  },
  "permissions": ["device:os.vibrator", "device:os.sensor"],
  "runtime": {
    "apiVersion": {
      "compatible": "4.0",
      "target": "4.0",
      "minVersion": "4.0"
    }
  },
  "targets": {
    "default": {
      "module": {
        "page": {
          "pages": [
            "page/index"
          ]
        },
        "app-side": {
          "path": "app-side/index"
        }
      },
      "platforms": [
        {
          "st": "r",
          "dw": 480
        }
      ]
    }
  },
  "i18n": {
    "en-US": {
      "appName": "RadiaWatch"
    }
  },
  "defaultLanguage": "en-US"
}
